{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member", "dealer", "super_admin"] },
        "dealerId": { "type": "string", "description": "ID of the tenant/dealer this user belongs to." },
        "lineCode": { "type": "string", "description": "Unique code for dealer network access." },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "username", "role", "createdAt"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "Information about a customer complaint submitted by a member.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "customerName": { "type": "string" },
        "area": { "type": "string" },
        "description": { "type": "string" },
        "number": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in process", "complete"] },
        "category": { "type": "string" },
        "priority": { "type": "string" },
        "pkgDetails": { "type": "string" },
        "userNearby": { "type": "string" },
        "panelDetails": { "type": "string" },
        "dealerId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "memberId", "memberName", "customerName", "status", "createdAt"]
    },
    "AdminConfig": {
      "title": "Admin Config",
      "description": "Global settings for the application reachable only by admins.",
      "type": "object",
      "properties": {
        "spreadsheetId": { "type": "string" }
      }
    },
    "AppConfig": {
      "title": "App Configuration",
      "description": "Dynamic categories, statuses, zones and priorities for the workflow.",
      "type": "object",
      "properties": {
        "categories": { "type": "array", "items": { "type": "string" } },
        "statuses": { "type": "array", "items": { "type": "string" } },
        "priorities": { "type": "array", "items": { "type": "string" } },
        "zones": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["categories", "statuses", "priorities", "zones"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single chat message sent by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "audioUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "voice"] },
        "duration": { "type": "number" },
        "dealerId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "senderId", "senderName", "createdAt"]
    },
    "Client": {
      "title": "Client",
      "description": "Stored client details for automatic form population.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "number": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "seriesNumber": { "type": "string" },
        "area": { "type": "string" },
        "pkgDetails": { "type": "string" },
        "userNearby": { "type": "string" },
        "panelDetails": { "type": "string" },
        "createdBy": { "type": "string" },
        "dealerId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "username", "name", "createdBy"]
    },
    "Alarm": {
      "title": "Emergency Alarm",
      "description": "State of the system-wide emergency alarm.",
      "type": "object",
      "properties": {
        "active": { "type": "boolean" },
        "triggeredAt": { "type": "string", "format": "date-time" },
        "triggeredBy": { "type": "string" }
      },
      "required": ["active", "triggeredAt", "triggeredBy"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Activity alerts for users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "authorName": { "type": "string" },
        "dealerId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "type", "message", "authorName", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Profiles for admins and members."
    },
    "complaints/{complaintId}": {
      "schema": "Complaint",
      "description": "All customer complaints logged in the system."
    },
    "clients/{clientId}": {
      "schema": "Client",
      "description": "Database of registered clients for easy lookups."
    },
    "config/settings": {
      "schema": "AdminConfig",
      "description": "System settings like Google Spreadsheet ID."
    },
    "config/app": {
      "schema": "AppConfig",
      "description": "Workflow categories, statuses and priorities."
    },
    "chat/{messageId}": {
      "schema": "Message",
      "description": "Real-time team communication."
    },
    "system/alarm": {
      "schema": "Alarm",
      "description": "Global emergency signal state."
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Activity broadcast notifications."
    }
  }
}
