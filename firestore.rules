rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Complete Access Rules ---
    // This allows full client-side operations, seeding, and offline-syncing queues
    // to function flawlessly on Netlify without blocking on anonymous authentication issues.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
