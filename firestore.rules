rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { 
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    
    // --- User Profiles ---
    function isValidUser(data) {
      return data.uid is string && 
             data.username is string && data.username.size() >= 3 && data.username.size() <= 50 &&
             data.role in ['admin', 'member'] &&
             data.createdAt is number;
    }

    match /users/{userId} {
      allow read: if true; // Public read needed for login logic if Auth is restricted
      allow create: if isValidId(userId) && isValidUser(request.resource.data);
      allow update, delete: if true; // Simplified for the public prototype
    }

    // --- Complaints ---
    function isValidComplaint(data) {
      return data.id is string &&
             data.memberId is string &&
             data.memberName is string &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.area is string &&
             data.description is string &&
             data.number is string &&
             data.status in ['pending', 'in process', 'complete', 'important'] &&
             // Handle legacy records that might be missing these fields
             (!('category' in data) || data.category is string) &&
             (!('priority' in data) || data.priority is string) &&
             data.createdAt is number;
    }

    function isValidMessage(data) {
      return data.id is string &&
             data.senderId is string &&
             data.senderName is string &&
             data.text is string && data.text.size() <= 1000 &&
             data.createdAt is number &&
             (data.seenBy == null || data.seenBy is map);
    }

    match /complaints/{complaintId} {
      allow read: if true; 
      allow create: if true; 
      allow update: if true; 
      allow delete: if true; 
    }

    match /chat/{messageId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /clients/{clientId} {
      allow read, write: if true;
    }

    // --- Notifications ---
    function isValidNotification(data) {
      return data.id is string &&
             data.type is string &&
             data.message is string &&
             data.authorName is string &&
             data.createdAt is number;
    }

    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // --- Config ---
    function isValidAppConfig(data) {
      return data.categories is list && data.categories.size() >= 1 &&
             data.statuses is list && data.statuses.size() >= 1 &&
             data.priorities is list && data.priorities.size() >= 1 &&
             data.zones is list && data.zones.size() >= 1;
    }

    function isValidWhatsAppConfig(data) {
      return data.registrationTemplate is string && data.registrationTemplate.size() <= 2000 &&
             data.completionTemplate is string && data.completionTemplate.size() <= 2000;
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if true; // Temporary allow for prototype to unblock dispatch config
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
