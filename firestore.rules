rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    function isDealer() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dealer';
    }

    function getDealerId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dealerId', 'main');
    }

    function getEffectiveDealerId() {
      return isDealer() ? request.auth.uid : getDealerId();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if true; 
      allow update: if true;
      allow delete: if true;
    }

    match /complaints/{complaintId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /clients/{clientId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /chat/{messageId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /typing/{uid} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
