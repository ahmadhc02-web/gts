rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // --- User Profiles ---
    function isValidUser(data) {
      return data.uid is string && 
             data.username is string && data.username.size() >= 3 && data.username.size() <= 50 &&
             data.role in ['admin', 'member'] &&
             data.createdAt is number;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(request.resource.data) && (
        // First user can be anything (bootstrapping) or admins can create
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || isAdmin()
      );
      allow update: if (isAdmin() || isOwner(userId)) && isValidUser(request.resource.data) &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['username', 'password', 'role']);
      allow delete: if isAdmin();
    }

    // --- Complaints ---
    function isValidComplaint(data) {
      return data.id is string &&
             data.memberId is string &&
             data.memberName is string &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.area is string &&
             data.description is string &&
             data.number is string &&
             data.status in ['pending', 'in process', 'complete', 'important'] &&
             data.createdAt is number;
    }

    match /complaints/{complaintId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.memberId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(complaintId) && isValidComplaint(request.resource.data) && (
        request.resource.data.memberId == request.auth.uid || isAdmin()
      );
      allow update: if isSignedIn() && isValidComplaint(request.resource.data) && (
        // Members can update their own if pending, or Admins any time
        (resource.data.memberId == request.auth.uid && resource.data.status == 'pending') || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // --- Config ---
    match /config/settings {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
