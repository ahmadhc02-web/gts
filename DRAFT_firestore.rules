rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role in ['super_admin', 'dealer', 'admin'];
    }

    function isMemberOfGroup(groupId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Config - Public read (for auth/setup), Admin write
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if true; // Allow registration
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Complaints
    match /complaints/{complaintId} {
      allow read: if isSignedIn(); // Basic read for all members in tenant usually, but kept simple for now
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // Add more logic later
      allow delete: if isAdmin();
    }

    // Clients
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Chat
    match /chat/{messageId} {
      allow read: if isSignedIn() && (
        !resource.data.recipientId || // Global
        resource.data.senderId == request.auth.uid || 
        resource.data.recipientId == request.auth.uid ||
        (resource.data.isGroup == true && isMemberOfGroup(resource.data.recipientId))
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && (
        isOwner(resource.data.senderId) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenBy']))
      );
      allow delete: if isAdmin() || isOwner(resource.data.senderId);
    }

    // Groups
    match /groups/{groupId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.members || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.members || isAdmin());
      allow delete: if isAdmin();
    }

    // Typing
    match /typing/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // System Alarm
    match /system/alarm {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
